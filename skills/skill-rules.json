{
  "version": "1.0",
  "description": "React Native skill triggers - executable skills only",
  "skills": {
    "frontend-dev-guidelines": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "file": "development/frontend-dev-guidelines.md",
      "promptTriggers": {
        "keywords": ["mobile", "react native", "screen", "navigation", "expo", "nativewind", "app", "ios", "android", "component", "ui", "form", "modal", "hook", "state", "redux"],
        "intentPatterns": [
          "(create|implement|build|add|update|fix).*?(screen|navigation|mobile|app|component|hook|context)",
          "(style|design|layout).*?(mobile|app|screen)",
          "(native|platform).*?(feature|module|component)",
          "(fetch|api|http).*?(service|call|request)"
        ]
      }
    },
    "figma-to-react-native": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "file": "converters/figma-to-react-native.md",
      "promptTriggers": {
        "keywords": ["figma", "convert figma", "figma to react native", "implement design", "design to mobile"],
        "intentPatterns": [
          "(convert|implement).*?figma",
          "figma.*?(react native|mobile|component|implementation)"
        ]
      }
    },
    "import-icons": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "file": "converters/import-icons.md",
      "promptTriggers": {
        "keywords": ["import icons", "figma icons", "svg icons", "download icons", "icon assets", "figma export", "svg export"],
        "intentPatterns": [
          "(import|download|export|fetch).*?(icons|svg).*?(figma)",
          "figma.*?(icons|svg|assets).*?(import|download|export)",
          "(icon|svg).*?(assets|files).*?(figma|export|download)"
        ]
      }
    },
